# ════════════════════════════════════════════════════════════════════════════
#  Synapse AutoAgent — environment
#  Copy to .env and fill in. NEVER commit .env (it is gitignored).
#  See docs/RUNBOOK.md for where each value comes from.
# ════════════════════════════════════════════════════════════════════════════

# ─── Synapse RPC Gateway ──────────────────────────────────────────────────────
# Free key: https://synapse.oobeprotocol.ai/signup  (api_key is a QUERY PARAM)
SYNAPSE_RPC="https://us-1-mainnet.oobeprotocol.ai/rpc?api_key=sk_live_XXXX"
SYNAPSE_API_KEY="sk_live_XXXX"
SYNAPSE_WS="wss://us-1-mainnet.oobeprotocol.ai/ws?api_key=sk_live_XXXX"
SYNAPSE_NETWORK="mainnet"
SYNAPSE_REGION="US-1"

# Fallback public RPC (rate-limited; used only if SYNAPSE_RPC is unset)
SOLANA_RPC_FALLBACK="https://api.mainnet-beta.solana.com"

# ─── Agent wallet (Solana mainnet keypair = identity + payer) ────────────────
# Provide ONE of these. Needs SOL (fees + 0.1 SOL register + stake) and USDC (payments).
SOLANA_KEYPAIR_PATH="./keys/agent.json"
# SOLANA_SECRET_KEY_BS58="<base58-encoded secret key>"

# ─── Ace Data Cloud (Category B) ─────────────────────────────────────────────
# Sign up (Google/GitHub → free credits): https://platform.acedata.cloud
# CLASSIC path uses a Bearer token; x402 path reuses the Solana keypair above (must hold USDC).
ACEDATA_API_TOKEN=""
ACEDATA_PAYMENT_MODE="x402"        # "x402" (crypto, no key) | "classic" (Bearer token)
ACEDATA_X402_NETWORK="solana"      # "solana" | "base" | "skale"

# ─── Agent identity / registration ───────────────────────────────────────────
AGENT_NAME="SynapseAutoAgent"
AGENT_DESCRIPTION="Autonomous agent: discovers SAP tools, runs AI workflows, settles via x402/escrow"
AGENT_X402_ENDPOINT="https://your-agent.example.com/x402"

# ─── Runtime ─────────────────────────────────────────────────────────────────
LOG_LEVEL="info"                   # trace|debug|info|warn|error
DRY_RUN="true"                     # true = simulate payments (no real tx); set false to go live on mainnet
WORKFLOWS_DIR="./workflows"
RECEIPTS_DIR="./receipts"
DASHBOARD_PORT="4040"
SCHEDULER_INTERVAL_MS="900000"     # 15 min between autonomous runs

# ─── Spend guardrails (atomic units) ─────────────────────────────────────────
MAX_USDC_PER_CALL="200000"         # 0.20 USDC ceiling per single paid call
MAX_USDC_PER_RUN="2000000"         # 2.00 USDC ceiling per workflow run
MAX_USDC_PER_DAY="20000000"        # 20.00 USDC ceiling per 24h
