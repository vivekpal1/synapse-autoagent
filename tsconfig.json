{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": false,
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@autoagent/config": ["packages/config/src/index.ts"],
      "@autoagent/wallet": ["packages/wallet/src/index.ts"],
      "@autoagent/x402": ["packages/x402/src/index.ts"],
      "@autoagent/sap": ["packages/sap/src/index.ts"],
      "@autoagent/acedata": ["packages/acedata/src/index.ts"],
      "@autoagent/core": ["packages/core/src/index.ts"]
    }
  },
  "include": ["packages/*/src/**/*", "apps/*/src/**/*", "scripts/**/*", "*.config.ts"],
  "exclude": ["node_modules", "**/dist/**", "**/*.test.ts"]
}
